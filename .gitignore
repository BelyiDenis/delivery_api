cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv

# Django
*.log
*.pot
*.pyc
local_settings.py
db.sqlite3
media/
staticfiles/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.coverage
htmlcov/
.tox/
.pytest_cache/

# MyPy
.mypy_cache/

# Environment variables
.env
.venv

# Migrations
*/migrations/00*.py
!*/migrations/__init__.py

# Backup files
*.bak
*.backup
EOF